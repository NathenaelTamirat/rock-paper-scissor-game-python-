{
  "name": "rock-paper-scissors",
  "version": "1.0.0",
  "description": "Rock Paper Scissors desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.rps.desktop",
    "productName": "Rock Paper Scissors",
    "files": [
      "main.js",
      "preload.js",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "backend",
        "filter": [
          "app/**/*",
          "static/**/*",
          "requirements.txt",
          "*.py"
        ]
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
